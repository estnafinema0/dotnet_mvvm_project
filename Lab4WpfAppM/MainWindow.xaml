<Window x:Class="Lab4WpfAppM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:local="clr-namespace:Lab4WpfAppM"
        mc:Ignorable="d"
    Title="Лабораторная работа 4 (MVVM)" Height="700" Width="1300">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5,0,5,10">
                <TextBlock Text="Дата выбранной строки:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <DatePicker SelectedDate="{Binding SelectedItem.Date,
                                          Mode=TwoWay,
                                          UpdateSourceTrigger=PropertyChanged,
                                          ValidatesOnDataErrors=True,
                                          NotifyOnValidationError=True}"
                    Width="200"/>
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <DockPanel Grid.Column="0" Margin="5" LastChildFill="True">
                    <TextBlock Text="DataGrid (Items)" FontWeight="Bold"
                       DockPanel.Dock="Top" Margin="0,0,0,5"/>
                    <DataGrid ItemsSource="{Binding Items}"
                      SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Width="*"
                        Binding="{Binding Name, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}"/>
                            <DataGridTextColumn Header="Date" Width="*"
                        Binding="{Binding Date, StringFormat=d,
                                  ValidatesOnDataErrors=True,
                                  UpdateSourceTrigger=PropertyChanged,
                                  NotifyOnValidationError=True}"/>
                            <DataGridTextColumn Header="N" Width="60"
                        Binding="{Binding N, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}"/>
                            <DataGridTextColumn Header="LeftBound" Width="*"
                        Binding="{Binding LeftBound, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}"/>
                            <DataGridTextColumn Header="RightBound" Width="*"
                        Binding="{Binding RightBound, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}"/>
                            <DataGridTextColumn Header="DList.Count" Width="90"
                        IsReadOnly="True"
                        Binding="{Binding DList.Count}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>

                <DockPanel Grid.Column="1" Margin="5" LastChildFill="True">
                    <TextBlock Text="Узлы и значения" FontWeight="Bold"
                       DockPanel.Dock="Top" Margin="0,0,0,5"/>
                    <ListBox ItemsSource="{Binding SelectedItem.GridRows}"/>
                </DockPanel>

            
                <DockPanel Grid.Column="2" Margin="5" LastChildFill="True">
                    <TextBlock Text="График" FontWeight="Bold"
                       DockPanel.Dock="Top" Margin="0,0,0,5"/>
                    <oxy:PlotView Model="{Binding SelectedItem.PlotModel}"/>
                </DockPanel>
            </Grid>
        </Grid>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5,15,5,5">
            <Button Content="Update"         Width="120" Margin="0,0,10,0"
                    Command="{Binding UpdateCommand}"/>
            <Button Content="Update Element" Width="140" Margin="0,0,10,0"
                    Command="{Binding UpdateElementCommand}"/>
            <Button Content="Output"         Width="120"
                    Command="{Binding OutputCommand}"/>
        </StackPanel>
    </Grid>
</Window>